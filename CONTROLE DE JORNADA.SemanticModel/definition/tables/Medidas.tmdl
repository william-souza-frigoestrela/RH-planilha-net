	measure 'Saldo Positivo' = ```
			
			VAR MinutosPositivos = SUM('Planilha NET – 2 – Saldo de Banco de Horas – saldo_data'[MINUTOS_SALDO_POSITIVO])
			VAR Horas = TRUNC(MinutosPositivos / 60)
			VAR Minutos = MOD(MinutosPositivos, 60)
			RETURN
			    -- Retorna BLANK() se for vazio ou zero para ocultar linhas sem dados no filtro
			    IF(
			        ISBLANK(MinutosPositivos) || MinutosPositivos = 0, 
			        BLANK(), 
			        FORMAT(Horas, "00") & ":" & FORMAT(Minutos, "00")
			    )
			```
		lineageTag: 1596ab93-a5b6-4892-9a3e-17b81aeb88a8

	measure 'Saldo Negativo' = ```
			
			VAR MinutosNegativos = SUM('Planilha NET – 2 – Saldo de Banco de Horas – saldo_data'[MINUTOS_SALDO_NEGATIVO])
			VAR ValorAbsoluto = ABS(MinutosNegativos)
			VAR Horas = TRUNC(ValorAbsoluto / 60)
			VAR Minutos = MOD(ValorAbsoluto, 60)
			RETURN
			    -- Retorna BLANK() se for vazio ou zero para ocultar linhas sem dados no filtro
			    IF(
			        ISBLANK(MinutosNegativos) || MinutosNegativos = 0, 
			        BLANK(), 
			        "-" & FORMAT(Horas, "00") & ":" & FORMAT(Minutos, "00")
			    )
			```
		lineageTag: 0931e136-d8ae-4427-9df0-cc822f83a03c

	measure Qtd_Funcionarios_Saldo_Positivo =
			
			COUNTROWS(
			    FILTER(
			        VALUES('Planilha NET – 2 – Saldo de Banco de Horas – saldo_data'[CODFILIAL-CHAPA]),
			        CALCULATE(SUM('Planilha NET – 2 – Saldo de Banco de Horas – saldo_data'[MINUTOS_SALDO_POSITIVO])) > 0
			    )
			)
		formatString: 0
		lineageTag: 9062065b-6272-4c94-8ae5-d37e8a6c3a3b

