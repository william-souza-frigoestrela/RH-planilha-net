	measure 'Filtro Slicer RLS' = ```
			
			
			VAR _UsuarioLogado = USERPRINCIPALNAME()
			
			-- 1. Verifica se o usuário logado está mapeado na tabela de restrições
			
			VAR _UsuarioEstaMapeado =
			    NOT(ISBLANK(
			        CALCULATE(
			            COUNTROWS('dAcessoUsuarios'),
			            ALL('dFilial'),
			            'dAcessoUsuarios'[EMAIL] = _UsuarioLogado
			        )
			    ))
			-- 2. Lista as filiais autorizadas para a Amanda
			VAR _FiliaisAutorizadas =
			    CALCULATETABLE(
			        VALUES('dAcessoUsuarios'[COLIGADA-FILIAL]),
			        ALL('dFilial'),
			        'dAcessoUsuarios'[EMAIL] = _UsuarioLogado
			    )
			
			-- 3. Captura o ID da linha que a árvore do Slicer está renderizando
			VAR _FilialSendoDesenhada = SELECTEDVALUE('dFilial'[ID_FILIAL])
			RETURN
			    IF(
			        _UsuarioEstaMapeado = FALSE(),
			        1, -- Usuário Master: Vê todas as opções   
			         -- Para usuário restrito: Mostra o nó pai (BLANK) ou se a filial for a autorizada
			        IF(ISBLANK(_FilialSendoDesenhada) || _FilialSendoDesenhada IN _FiliaisAutorizadas, 1, 0)
			    )
			
			
			```
		formatString: 0
		lineageTag: 20da9c5f-d812-4499-9ff1-30a729a32d78

	measure 'Filtro Hierarquia RLS' = ```
			
			VAR _UsuarioLogado = USERPRINCIPALNAME()
			
			-- 1. Checa se o usuário logado está mapeado na tabela de restrições
			VAR _UsuarioEstaMapeado = 
			    NOT(ISBLANK(
			        CALCULATE(
			            COUNTROWS('dAcessoUsuarios'), 
			            ALL('dFilial'),
			            'dAcessoUsuarios'[EMAIL] = _UsuarioLogado
			        )
			    ))
			
			-- 2. Captura quantas filiais existem no total para a coligada que está no contexto
			VAR _TotalFiliaisDaColigada = CALCULATE(DISTINCTCOUNT('dFilial'[FILIAL]), ALLSELECTED('dFilial'[FILIAL]))
			
			-- 3. Verifica se o usuário selecionou uma quantidade menor de filiais do que o nó pai completo
			VAR _FilialEstaSelecionadaDiretamente = 
			    ISFILTERED('dFilial'[FILIAL]) && HASONEVALUE('dFilial'[FILIAL])
			
			-- 4. Lista os departamentos autorizados para o usuário logado
			VAR _DepartamentosAutorizados = 
			    CALCULATETABLE(
			        VALUES('dAcessoUsuarios'[CODDEPARTAMENTO]),
			        ALL('dFilial'),
			        'dAcessoUsuarios'[EMAIL] = _UsuarioLogado
			    )
			
			-- 5. Verifica se o usuário logado possui restrição específica de departamento (campo preenchido na dAcessoUsuarios)
			VAR _PossuiRestricaoDeDepartamento = 
			    NOT(ISEMPTY(
			        FILTER(
			            _DepartamentosAutorizados, 
			            NOT(ISBLANK('dAcessoUsuarios'[CODDEPARTAMENTO])) && 'dAcessoUsuarios'[CODDEPARTAMENTO] <> ""
			        )
			    ))
			
			RETURN
			    IF(
			        _UsuarioEstaMapeado = FALSE(),
			        1, -- Usuário Master: Vê tudo sempre livremente
			        
			        -- Para usuário restrito:
			        IF(
			            _FilialEstaSelecionadaDiretamente = TRUE(),
			            -- Se a filial está selecionada diretamente, agora aplicamos a validação de departamento
			            IF(
			                _PossuiRestricaoDeDepartamento,
			                -- ALTERAÇÃO AQUI: Captura todos os departamentos ativos no contexto atual (suporta múltiplos)
			                VAR _DeptosNoContexto = VALUES('FPBI_DEPARTAMENTO'[CODDEPARTAMENTO])
			                RETURN
			                    -- Verifica se há intersecção entre os departamentos selecionados/visíveis e os autorizados
			                    IF(
			                        NOT(ISEMPTY(INTERSECT(_DeptosNoContexto, _DepartamentosAutorizados))),
			                        1,
			                        0
			                    ),
			                1 -- Se ele não tem restrição de depto, libera todos os deptos da filial
			            ),
			            0  -- Se marcar o Pai inteiro (todas as filiais da coligada ativas) ou limpar, bloqueia
			        )
			    )
			```
		formatString: 0
		lineageTag: 4baf5fa0-e00b-4f70-b261-5edb9eb2be26

	measure 'Filtro Slicer Departamento RLS' = ```
			
			VAR _UsuarioLogado = USERPRINCIPALNAME()
			
			-- 1. Verifica se o usuário logado está mapeado na tabela de restrições
			VAR _UsuarioEstaMapeado =
			    NOT(ISBLANK(
			        CALCULATE(
			            COUNTROWS('dAcessoUsuarios'),
			            ALL('dFilial'),
			            'dAcessoUsuarios'[EMAIL] = _UsuarioLogado
			        )
			    ))
			
			-- 2. Lista os departamentos autorizados para o usuario (tratando vazios)
			VAR _DepartamentosAutorizados =
			    CALCULATETABLE(
			        VALUES('dAcessoUsuarios'[CODDEPARTAMENTO]),
			        ALL('dFilial'),
			        'dAcessoUsuarios'[EMAIL] = _UsuarioLogado
			    )
			
			-- 3. Captura o ID do departamento que a árvore do Slicer está renderizando
			-- (Substitua 'FPBI_DEPARTAMENTO'[CODDEPARTAMENTO] pela coluna de ID de departamento usada no seu slicer)
			VAR _DeptoSendoDesenhado = SELECTEDVALUE('FPBI_DEPARTAMENTO'[CODDEPARTAMENTO])
			
			-- 4. Verifica se o usuário tem alguma restrição de departamento preenchida na tabela
			VAR _PossuiRestricaoDeDepartamento = 
			    NOT(ISEMPTY(
			        FILTER(_DepartamentosAutorizados, NOT(ISBLANK('dAcessoUsuarios'[CODDEPARTAMENTO])) && 'dAcessoUsuarios'[CODDEPARTAMENTO] <> "")
			    ))
			
			RETURN
			    IF(
			        _UsuarioEstaMapeado = FALSE(),
			        1, -- Usuário Master: Vê todas as opções   
			        
			        -- Para usuário restrito:
			        IF(
			            _PossuiRestricaoDeDepartamento = FALSE(),
			            1, -- Se o usuário não tem nenhuma restrição de departamento (está null/vazio), liberamos todos
			            
			            -- Se ele tem restrição, mostra o nó pai da hierarquia (BLANK) ou o departamento autorizado
			            IF(ISBLANK(_DeptoSendoDesenhado) || _DeptoSendoDesenhado IN _DepartamentosAutorizados, 1, 0)
			        )
			    )
			```
		formatString: 0
		lineageTag: 60f5714e-3ab4-4694-8c87-67c5b98d37c2

	measure 'Qtd HE acima 6H' = COUNTROWS('Planilha NET 24 - Acima de 6 horas sem intervalo')
		formatString: 0
		lineageTag: 79e4cfdc-02d8-4f88-8063-4ec5b23b850b

	measure '''Filtro Departamento RLS (Faltas)''' =
			
			VAR _UsuarioLogado = USERPRINCIPALNAME()
			VAR _UsuarioEstaMapeado =
			    NOT(ISBLANK(CALCULATE(COUNTROWS('dAcessoUsuarios'), ALL('dFilial'), 'dAcessoUsuarios'[EMAIL] = _UsuarioLogado)))
			VAR _DepartamentosAutorizados =
			    CALCULATETABLE(VALUES('dAcessoUsuarios'[CODDEPARTAMENTO]), ALL('dFilial'), 'dAcessoUsuarios'[EMAIL] = _UsuarioLogado)
			VAR _PossuiRestricao =
			    NOT(ISEMPTY(FILTER(_DepartamentosAutorizados, NOT(ISBLANK('dAcessoUsuarios'[CODDEPARTAMENTO])) && 'dAcessoUsuarios'[CODDEPARTAMENTO] <> "")))
			VAR _DeptoDaLinha =
			    SELECTEDVALUE('Planilha NET 4 – Faltas'[CODDEPARTAMENTO])
			RETURN
			    IF(
			        _UsuarioEstaMapeado = FALSE(), 1,
			        IF(
			            _PossuiRestricao = FALSE(), 1,
			            IF(_DeptoDaLinha IN _DepartamentosAutorizados, 1, 0)
			        )
			    )
		formatString: 0
		lineageTag: a6ec17b4-31ff-41f7-b451-5a32e4510f59

