model Model
	culture: pt-BR
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: pt-BR
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

/// Erros nas consultas que foram carregadas em 25/06/2026 08:24:13.
queryGroup 'Erros na Consulta - 25/06/2026 08:24:13'

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Planilha NET- 27 – Acima de 10 Horas - Top Dias","Planilha NET- 4 – Faltas","Planilha NET – 2 – Saldo de Banco de Horas – saldo_data","Planilha NET 26 - Funcionários com Jornada","Planilha NET- 27 – Acima de 10 Horas - Func","Planilha NET- 27 – Acima de 10 Horas - Valor","Erros em Planilha NET- 27 – Acima de 10 Horas - Func","Erros em Planilha NET- 27 – Acima de 10 Horas - Valor","dCODCOLIGADA","dCODFILIAL"]

annotation PBI_ProTooling = ["DevMode"]

ref table 'Planilha NET- 27 – Acima de 10 Horas - Top Dias'
ref table 'Planilha NET- 4 – Faltas'
ref table 'Planilha NET – 2 – Saldo de Banco de Horas – saldo_data'
